rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /* ─── Auth helpers ───────────────────────────────────────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function isFamilyOwner(familyId) {
      return isSignedIn()
        && familyDoc(familyId).owner_id == request.auth.uid;
    }

    function staffPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId)/staff/$(request.auth.uid);
    }

    function isFamilyStaff(familyId) {
      return isSignedIn() && exists(staffPath(familyId));
    }

    function staffRole(familyId) {
      return get(staffPath(familyId)).data.role;
    }

    function isFamilyStaffWriter(familyId) {
      return isFamilyStaff(familyId)
        && staffRole(familyId) in ['truong_ho', 'truong_chi', 'editor'];
    }

    /** Custom claim branch_admin — hỗ trợ branch_id đơn hoặc branch_ids[] */
    function isClaimBranchAdmin() {
      return isSignedIn()
        && request.auth.token.role == 'branch_admin'
        && request.auth.token.family_id is string;
    }

    function claimHasBranch(branchId) {
      return (
        (
          request.auth.token.keys().hasAny(['branch_ids'])
          && request.auth.token.branch_ids is list
          && branchId in request.auth.token.branch_ids
        )
        || (
          request.auth.token.keys().hasAny(['branch_id'])
          && request.auth.token.branch_id == branchId
        )
      );
    }

    /** Trưởng nhánh trong collection family_managers (doc id = familyId__uid) */
    function listedManagerDoc(familyId) {
      return get(/databases/$(database)/documents/family_managers/$(familyId + '__' + request.auth.uid));
    }

    function managerHasBranch(data, branchId) {
      return (
        (
          data.keys().hasAny(['branch_ids'])
          && data.branch_ids is list
          && branchId in data.branch_ids
        )
        || data.branch_id == branchId
      );
    }

    function isListedBranchAdmin(familyId, branchId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/family_managers/$(familyId + '__' + request.auth.uid))
        && listedManagerDoc(familyId).data.status == 'active'
        && listedManagerDoc(familyId).data.family_id == familyId
        && managerHasBranch(listedManagerDoc(familyId).data, branchId);
    }

    function isBranchAdminFor(familyId, branchId) {
      return (
        isClaimBranchAdmin()
        && request.auth.token.family_id == familyId
        && claimHasBranch(branchId)
      ) || isListedBranchAdmin(familyId, branchId);
    }

    /** branch_id nằm trong tree_logic (schema mới) */
    function memberBranchId(data) {
      return data.tree_logic.branch_id;
    }

    function branchAdminMatches(data) {
      return hasFamilyId(data)
        && data.keys().hasAll(['tree_logic'])
        && isBranchAdminFor(data.family_id, memberBranchId(data));
    }

    function hasFamilyId(data) {
      return data.keys().hasAll(['family_id'])
        && data.family_id is string
        && data.family_id.size() > 0;
    }

    function hasNoContactField() {
      return !request.resource.data.keys().hasAny(['contact']);
    }

    function canWriteMember(data) {
      return isSuperAdmin()
        || isFamilyOwner(data.family_id)
        || isFamilyStaffWriter(data.family_id)
        || branchAdminMatches(data);
    }

    /* ─── registration_keys (tra trùng email/SĐT công khai) ─── */

    match /registration_keys/{key} {
      allow read: if true;
      allow create: if isSuperAdmin()
        || (
          isSignedIn()
          && request.resource.data.keys().hasAll(['registration_id', 'status'])
          && request.resource.data.status == 'pending'
        );
      allow update: if isSuperAdmin()
        || (
          isSignedIn()
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'pending'
        );
      allow delete: if isSuperAdmin();
    }

    /* ─── family_registrations (đăng ký chờ duyệt) ───────────── */

    match /family_registrations/{regId} {
      allow read: if isSuperAdmin()
        || (isSignedIn() && resource.data.applicant_uid == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.applicant_uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
          'applicant_uid', 'full_name', 'family_surname', 'email', 'phone',
          'address', 'family_name', 'status', 'norm_email', 'norm_phone',
          'norm_surname', 'norm_family_name'
        ]);

      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin()
        || (
          isSignedIn()
          && resource.data.applicant_uid == request.auth.uid
          && resource.data.status == 'pending'
          && (
            !('family_id' in resource.data)
            || resource.data.family_id == null
          )
        );
    }

    /* ─── families ───────────────────────────────────────────── */

    match /families/{familyId} {
      allow read: if true || isSuperAdmin();

      /** Chỉ Super Admin tạo sau khi duyệt đăng ký */
      allow create: if isSuperAdmin()
        && request.resource.data.keys().hasAll(['name', 'owner_id']);

      allow update, delete: if isSuperAdmin() || isFamilyOwner(familyId);

      match /staff/{uid} {
        allow read: if isSuperAdmin()
          || isFamilyOwner(familyId)
          || isFamilyStaff(familyId);

        allow write: if isSuperAdmin()
          || isFamilyOwner(familyId)
          || (isFamilyStaff(familyId) && staffRole(familyId) == 'truong_ho');
      }
    }

    /* ─── family_managers (trưởng nhánh do chủ mời) ─────────── */

    match /family_managers/{managerId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || (
          resource.data.keys().hasAll(['family_id'])
          && (
            isFamilyOwner(resource.data.family_id)
            || resource.data.uid == request.auth.uid
            || resource.data.email == request.auth.token.email
          )
        )
      );

      allow create: if isSignedIn() && (
        isSuperAdmin()
        || (
          isFamilyOwner(request.resource.data.family_id)
          && request.resource.data.keys().hasAll(['family_id', 'email', 'role', 'status'])
          && (
            request.resource.data.keys().hasAny(['branch_ids'])
            || request.resource.data.keys().hasAny(['branch_id'])
          )
        )
      );

      allow update: if isSignedIn() && (
        isSuperAdmin()
        || isFamilyOwner(resource.data.family_id)
        || (
          resource.data.email == request.auth.token.email
          && request.resource.data.email == resource.data.email
          && request.resource.data.family_id == resource.data.family_id
          && request.resource.data.branch_id == resource.data.branch_id
          && (
            !resource.data.keys().hasAny(['branch_ids'])
            || request.resource.data.branch_ids == resource.data.branch_ids
          )
        )
      );

      allow delete: if isSuperAdmin() || (
        resource.data.keys().hasAll(['family_id'])
        && isFamilyOwner(resource.data.family_id)
      );
    }

    /* ─── family_members ─────────────────────────────────────── */

    match /family_members/{memberId} {
      allow read: if hasFamilyId(resource.data) || isSuperAdmin();

      allow create: if hasFamilyId(request.resource.data)
        && hasNoContactField()
        && request.resource.data.keys().hasAll(['tree_logic'])
        && canWriteMember(request.resource.data);

      allow update: if hasFamilyId(resource.data)
        && hasFamilyId(request.resource.data)
        && request.resource.data.family_id == resource.data.family_id
        && hasNoContactField()
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || isFamilyStaffWriter(resource.data.family_id)
          || (
            branchAdminMatches(resource.data)
            && branchAdminMatches(request.resource.data)
          )
        );

      allow delete: if hasFamilyId(resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || isFamilyStaffWriter(resource.data.family_id)
          || branchAdminMatches(resource.data)
        );

      match /sensitive/{docId} {
        allow read, write: if isSuperAdmin()
          || (
            isSignedIn()
            && hasFamilyId(
              get(/databases/$(database)/documents/family_members/$(memberId)).data
            )
            && (
              isFamilyOwner(
                get(/databases/$(database)/documents/family_members/$(memberId)).data.family_id
              )
              || canWriteMember(
                get(/databases/$(database)/documents/family_members/$(memberId)).data
              )
            )
          );
      }
    }

    /* ─── family_relations ───────────────────────────────────── */

    match /family_relations/{relationId} {
      allow read: if hasFamilyId(resource.data) || isSuperAdmin();

      allow create: if hasFamilyId(request.resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(request.resource.data.family_id)
          || isFamilyStaffWriter(request.resource.data.family_id)
          || isBranchAdminFor(
            request.resource.data.family_id,
            request.resource.data.branch_id
          )
        );

      allow update: if hasFamilyId(resource.data)
        && request.resource.data.family_id == resource.data.family_id
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || isFamilyStaffWriter(resource.data.family_id)
          || (
            isBranchAdminFor(resource.data.family_id, resource.data.branch_id)
            && request.resource.data.branch_id == resource.data.branch_id
          )
        );

      allow delete: if hasFamilyId(resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || isFamilyStaffWriter(resource.data.family_id)
          || isBranchAdminFor(resource.data.family_id, resource.data.branch_id)
        );
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /* ─── Auth helpers ───────────────────────────────────────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function isFamilyOwner(familyId) {
      return isSignedIn()
        && familyDoc(familyId).owner_id == request.auth.uid;
    }

    function isClaimBranchAdmin() {
      return isSignedIn()
        && request.auth.token.role == 'branch_admin'
        && request.auth.token.family_id is string
        && request.auth.token.branch_id is string;
    }

    /** Trưởng nhánh trong collection family_managers (doc id = familyId__uid) */
    function listedManagerDoc(familyId) {
      return get(/databases/$(database)/documents/family_managers/$(familyId + '__' + request.auth.uid));
    }

    function isListedBranchAdmin(familyId, branchId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/family_managers/$(familyId + '__' + request.auth.uid))
        && listedManagerDoc(familyId).data.status == 'active'
        && listedManagerDoc(familyId).data.family_id == familyId
        && listedManagerDoc(familyId).data.branch_id == branchId;
    }

    function isBranchAdminFor(familyId, branchId) {
      return (
        isClaimBranchAdmin()
        && request.auth.token.family_id == familyId
        && request.auth.token.branch_id == branchId
      ) || isListedBranchAdmin(familyId, branchId);
    }

    /** branch_id nằm trong tree_logic (schema mới) */
    function memberBranchId(data) {
      return data.tree_logic.branch_id;
    }

    function branchAdminMatches(data) {
      return hasFamilyId(data)
        && data.keys().hasAll(['tree_logic'])
        && isBranchAdminFor(data.family_id, memberBranchId(data));
    }

    function hasFamilyId(data) {
      return data.keys().hasAll(['family_id'])
        && data.family_id is string
        && data.family_id.size() > 0;
    }

    function hasNoContactField() {
      return !request.resource.data.keys().hasAny(['contact']);
    }

    function pathTooDeepToDelete() {
      return resource.data.keys().hasAll(['tree_logic'])
        && resource.data.tree_logic.keys().hasAll(['path'])
        && resource.data.tree_logic.path is list
        && resource.data.tree_logic.path.size() > 2;
    }

    function canWriteMember(data) {
      return isSuperAdmin()
        || isFamilyOwner(data.family_id)
        || branchAdminMatches(data);
    }

    /* ─── families ───────────────────────────────────────────── */

    match /families/{familyId} {
      allow read: if true || isSuperAdmin();

      allow create: if isSuperAdmin()
        || (
          isSignedIn()
          && request.resource.data.owner_id == request.auth.uid
          && request.resource.data.keys().hasAll(['name', 'owner_id'])
        );

      allow update, delete: if isSuperAdmin() || isFamilyOwner(familyId);
    }

    /* ─── family_managers (trưởng nhánh do chủ mời) ─────────── */

    match /family_managers/{managerId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || (
          resource.data.keys().hasAll(['family_id'])
          && (
            isFamilyOwner(resource.data.family_id)
            || resource.data.uid == request.auth.uid
            || resource.data.email == request.auth.token.email
          )
        )
      );

      allow create: if isSignedIn() && (
        isSuperAdmin()
        || (
          request.resource.data.keys().hasAll(['family_id', 'email', 'branch_id', 'role', 'status'])
          && (
            isFamilyOwner(request.resource.data.family_id)
            // Người được mời tự claim: tạo doc familyId__uid từ lời mời pending
            || (
              request.resource.data.uid == request.auth.uid
              && request.resource.data.status == 'active'
              && request.resource.data.email == request.auth.token.email
            )
          )
        )
      );

      allow update: if isSignedIn() && (
        isSuperAdmin()
        || isFamilyOwner(resource.data.family_id)
        || (
          // Claim / cập nhật uid của chính mình
          resource.data.email == request.auth.token.email
          && request.resource.data.email == resource.data.email
          && request.resource.data.family_id == resource.data.family_id
          && request.resource.data.branch_id == resource.data.branch_id
        )
      );

      allow delete: if isSuperAdmin() || (
        resource.data.keys().hasAll(['family_id'])
        && isFamilyOwner(resource.data.family_id)
      );
    }

    /* ─── family_members ─────────────────────────────────────── */

    match /family_members/{memberId} {
      allow read: if hasFamilyId(resource.data) || isSuperAdmin();

      allow create: if hasFamilyId(request.resource.data)
        && hasNoContactField()
        && request.resource.data.keys().hasAll(['tree_logic'])
        && canWriteMember(request.resource.data);

      allow update: if hasFamilyId(resource.data)
        && hasFamilyId(request.resource.data)
        && request.resource.data.family_id == resource.data.family_id
        && hasNoContactField()
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || (
            branchAdminMatches(resource.data)
            && branchAdminMatches(request.resource.data)
          )
        );

      allow delete: if hasFamilyId(resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || (branchAdminMatches(resource.data) && !pathTooDeepToDelete())
        );

      match /sensitive/{docId} {
        allow read, write: if isSuperAdmin()
          || (
            isSignedIn()
            && hasFamilyId(
              get(/databases/$(database)/documents/family_members/$(memberId)).data
            )
            && canWriteMember(
              get(/databases/$(database)/documents/family_members/$(memberId)).data
            )
          );
      }
    }

    /* ─── family_relations ───────────────────────────────────── */

    match /family_relations/{relationId} {
      allow read: if hasFamilyId(resource.data) || isSuperAdmin();

      allow create: if hasFamilyId(request.resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(request.resource.data.family_id)
          || isBranchAdminFor(
            request.resource.data.family_id,
            request.resource.data.branch_id
          )
        );

      allow update: if hasFamilyId(resource.data)
        && request.resource.data.family_id == resource.data.family_id
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || (
            isBranchAdminFor(resource.data.family_id, resource.data.branch_id)
            && request.resource.data.branch_id == resource.data.branch_id
          )
        );

      allow delete: if hasFamilyId(resource.data)
        && (
          isSuperAdmin()
          || isFamilyOwner(resource.data.family_id)
          || isBranchAdminFor(resource.data.family_id, resource.data.branch_id)
        );
    }
  }
}

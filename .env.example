NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Super Admin / phân quyền (server-side — không commit file JSON)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_PROJECT_ID=

# Cloudflare R2 — ảnh đại diện thành viên (S3-compatible)
# Tạo API token tại R2 → Manage API Tokens (Object Read & Write)
# Bật Public Development URL hoặc gắn custom domain cho bucket
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=giapha-photos
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
